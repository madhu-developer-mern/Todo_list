{
  "name": "todo-project",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace=backend run dev\" \"npm --workspace=frontend run dev\"",
    "client": "npm --workspace=frontend run dev",
    "server": "npm --workspace=backend run dev",
    "build": "npm --workspace=frontend run build",
    "lint": "eslint .",
    "preview": "npm --workspace=frontend run preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
